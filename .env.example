# MetaClaw Docker 环境配置

# 渠道类型：weixin, feishu, dingtalk, qq, terminal
CHANNEL_TYPE=feishu

# AI 模型
MODEL=MiniMax-M2.7

# API Key（必填）
MINIMAX_API_KEY=your-api-key-here

# 是否启用 Agent 模式
AGENT_MODE=true

# Web 控制台密码（可选，留空则不设密码）
WEB_PASSWORD=

# 数据目录
METACLAW_WORKSPACE=/app/workspace

# 日志级别：DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
