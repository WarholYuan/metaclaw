{
  "name": "@mianhuatang913/metaclaw",
  "version": "0.2.0",
  "description": "MetaClaw release installer and CLI bootstrapper",
  "license": "MIT",
  "author": "mianhuatang913",
  "keywords": [
    "metaclaw",
    "ai",
    "agent",
    "wechat",
    "feishu",
    "installer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WarholYuan/MetaClaw.git"
  },
  "homepage": "https://github.com/WarholYuan/MetaClaw#readme",
  "bugs": {
    "url": "https://github.com/WarholYuan/MetaClaw/issues"
  },
  "bin": {
    "metaclaw": "npm/bin/metaclaw-install.js",
    "metaclaw-install": "npm/bin/metaclaw-install.js"
  },
  "files": [
    "npm/bin/metaclaw-install.js",
    "scripts/install.sh",
    "README.md",
    "INSTALL.md"
  ],
  "scripts": {
    "install:local": "bash scripts/install.sh",
    "test": "node --test npm/bin/metaclaw-install.test.mjs",
    "test:coverage": "c8 npm test",
    "test:bats": "bats tests/install.bats",
    "lint:sh": "shellcheck scripts/install.sh",
    "lint:js": "node --check npm/bin/metaclaw-install.js",
    "prepare": "husky",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "standard-version": "^9.5.0"
  }
}
